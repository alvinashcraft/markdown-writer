{
  "name": "markdown-writer",
  "private": true,
  "version": "1.0.0",
  "description": "QuietMark — A distraction-free markdown editor with live preview",
  "author": "alash",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:preview": "vite build && electron .",
    "electron:build": "vite build && electron-builder",
    "electron:build:dir": "vite build && electron-builder --dir",
    "msix:pack": "npx winapp pack ./release/win-arm64-unpacked --generate-cert --output release/MarkdownWriter.msix",
    "msix:build": "npm run electron:build:dir && npm run msix:pack",
    "mas:build": "vite build && electron-builder --mac mas",
    "mas:build:dir": "vite build && electron-builder --mac mas --dir"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@fluentui/react-components": "^9.73.2",
    "@fluentui/react-icons": "^2.0.320",
    "dompurify": "^3.3.2",
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "marked": "^17.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.6",
    "wait-on": "^8.0.3"
  },
  "optionalDependencies": {
    "@microsoft/winappcli": "^0.2.0"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "build": {
    "appId": "com.alvinashcraft.markdownwriter",
    "productName": "QuietMark",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "locales/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "Assets/icon512.png",
      "target": "nsis"
    },
    "mac": {
      "icon": "Assets/icon1024.png",
      "target": "dmg",
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "12.0"
    },
    "mas": {
      "entitlements": "build/entitlements.mas.plist",
      "entitlementsInherit": "build/entitlements.mas.inherit.plist",
      "provisioningProfile": "build/embedded.provisionprofile",
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "12.0"
    }
  }
}
