{
  "name": "markdown-writer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:preview": "vite build && electron .",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "dompurify": "^3.3.2",
    "marked": "^17.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.6",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "build": {
    "appId": "com.markdownwriter.app",
    "productName": "Markdown Writer",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
